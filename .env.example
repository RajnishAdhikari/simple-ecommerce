APP_ENV=development
DATABASE_URL=postgresql+psycopg2://ecommerce:ecommerce@localhost:5432/ecommerce_db
SECRET_KEY=replace-with-a-strong-random-secret-32-plus-chars
ADMIN_API_KEY=replace-with-a-strong-random-admin-api-key-32-plus-chars
ADMIN_EMAILS=admin@example.com
POSTGRES_PASSWORD=replace-with-a-strong-random-postgres-password
TOKEN_EXPIRE_MINUTES=30
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
IMAGE_ALLOWED_HOSTS=images.unsplash.com
TRUST_X_FORWARDED_FOR=false
JWT_ISSUER=skycart-api
JWT_AUDIENCE=skycart-web
PBKDF2_ITERATIONS=240000
